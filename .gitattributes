# Normalize line endings for cross-platform consistency
* text=auto

# Force LF for source files (prevents Windows CRLF commits)
*.js    text eol=lf
*.jsx   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.json  text eol=lf
*.py    text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.env*  text eol=lf
*.csv   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Binary files — don't touch line endings
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.mp4   binary
*.db    binary
